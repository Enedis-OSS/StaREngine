# ---------------------------------------------------------------------------
# .gitignore — star_engine
# ---------------------------------------------------------------------------

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Pytest ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Mypy / Pylance / type checkers ────────────────────────────────────────
.mypy_cache/
.pytype/

# ── IDE / Éditeurs ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── Données de travail (GML, GeoJSON, PDF générés) ────────────────────────
*.gml
*.geojson
*.pdf

# ── Logs ───────────────────────────────────────────────────────────────────
*.log

# ── Environnements virtuels ───────────────────────────────────────────────
.venv/
venv/
env/
